{
  "name": "strategylab-ai",
  "private": true,
  "workspaces": [
    "apps/web",
    "packages/shared"
  ],
  "scripts": {
    "build": "npm run web:build",
    "web:dev": "npm --prefix apps/web run dev",
    "web:build": "npm --prefix apps/web run build",
    "web:lint": "npm --prefix apps/web run lint",
    "api:dev": "cd apps/api && uvicorn app.main:app --reload",
    "api:test": "cd apps/api && pytest",
    "dev": "echo \"Run npm run web:dev and npm run api:dev in separate terminals.\""
  }
}
